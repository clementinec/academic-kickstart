---
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  homeFocus,
  homeTeamSummary,
  homeWork,
  lab,
  profile,
  publications
} from "../data/site";

const topicColors = {
  "thermal comfort": "var(--card-pink)",
  "human heat": "var(--card-cream)",
  climate: "var(--card-blue)",
  energy: "var(--card-yellow)",
  control: "var(--card-blue)",
  ventilation: "var(--card-yellow)"
};

const publicationColor = (item) => topicColors[item.tags?.[0]] ?? "var(--card-cream)";
const featuredPublications = publications.journals.slice(0, 3);
---

<BaseLayout
  title="FORGE | Future, Occupant, Risk, and Generative Environments"
  description={lab.shortDescription}
  activePath="/"
>
  <section class="home-hero">
    <div class="hero-copy">
      <p class="eyebrow">{lab.name}</p>
      <h1>
        Writing people back to architecture and energy systems for various futures.
      </h1>
      <p class="hero-lead">{lab.shortDescription}</p>
      <p class="hero-summary">{lab.longName}</p>
      <div class="hero-links">
        <a class="text-link" href="/research">Research</a>
        <a class="text-link" href="/publications">Publications</a>
        <a class="text-link" href="/team">Team</a>
        <a class="text-link" href="/pi">PI</a>
      </div>
    </div>

    <aside class="hero-aside">
      <a class="pi-hover-card" href="/pi" aria-label={`Open ${profile.name} PI page`}>
        <div class="image-card square-panel">
          <img
            class="profile-image square-image"
            src="/images/profile.png"
            alt={`Portrait of ${profile.name}`}
            width="548"
            height="516"
          />
        </div>
        <div class="card-copy mini-card emerge-card">
          <p class="eyebrow">Name card</p>
          <h2>{profile.name}</h2>
          <p class="profile-role">{profile.role}</p>
          <p>{profile.department}, {profile.institution}</p>
        </div>
      </a>
    </aside>
  </section>

  <section class="home-columns">
    <div class="section-shell soft-card">
      <div class="section-header">
        <p class="eyebrow">What we're doing</p>
        <h2>Current focus</h2>
      </div>
      <p>{homeFocus.intro}</p>
      <ul class="focus-cloud" aria-label="Current focus areas">
        {homeFocus.items.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </div>

    <div class="section-shell accent-card">
      <div class="section-header">
        <p class="eyebrow">Why FORGE?</p>
        <h2>{lab.name}</h2>
      </div>
      <p>{lab.why}</p>
    </div>
  </section>

  <section class="home-columns">
    <div class="section-shell">
      <div class="section-header">
        <p class="eyebrow">Who’s here</p>
        <h2>Current team</h2>
      </div>
      <p>{homeTeamSummary}</p>
      <a class="text-link" href="/team">Open Team</a>
    </div>

    <div class="section-shell quiet-card">
      <div class="section-header">
        <p class="eyebrow">What we work on</p>
        <h2>Method signals</h2>
      </div>
      <p>{homeWork.intro}</p>
      <ul class="method-cloud" aria-label="Method signals">
        {homeWork.methods.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </div>
  </section>

  <section class="home-band">
    <div class="section-header">
      <p class="eyebrow">Recent output</p>
      <h2>Selected publications</h2>
    </div>
    <div class="publication-card-grid">
      {featuredPublications.map((paper) => (
        <article class="publication-card">
          <p class="publication-meta">{paper.venue} · {paper.year}</p>
          <h3>{paper.title}</h3>
          <p class="publication-summary">{paper.summary || paper.note || paper.venue}</p>
          <p class="note">{paper.authors}</p>
          {paper.doi && (
            <a
              class="publication-link"
              href={paper.doi}
              target="_blank"
              rel="noreferrer"
              style={`--hover-color: ${publicationColor(paper)};`}
            >
              Read paper <span class="link-arrow" aria-hidden="true">-&gt;</span>
            </a>
          )}
          <div class="publication-tags">
            {paper.tags?.map((tag) => (
              <span>{tag}</span>
            ))}
          </div>
        </article>
      ))}
    </div>
    <a class="text-link section-link" href="/publications">Browse all publications</a>
  </section>
</BaseLayout>
