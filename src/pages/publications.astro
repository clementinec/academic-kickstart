---
import BaseLayout from "../layouts/BaseLayout.astro";
import { publications } from "../data/site";

const topicColors = {
  "thermal comfort": "var(--card-pink)",
  "human heat": "var(--card-cream)",
  climate: "var(--card-blue)",
  energy: "var(--card-yellow)",
  control: "var(--card-blue)",
  ventilation: "var(--card-yellow)"
};

const publicationColor = (item) => topicColors[item.tags?.[0]] ?? "var(--card-cream)";

const groups = [
  {
    title: "Selected journal articles since joining HKU",
    items: publications.journals,
    kind: "journal"
  },
  {
    title: "Selected refereed conference and workshop papers since joining HKU",
    items: publications.proceedings,
    kind: "proceeding"
  }
];
---

<BaseLayout
  title="Publications | FORGE"
  description="Selected publications and manuscripts associated with FORGE."
  activePath="/publications"
>
  <section class="page-intro narrow">
    <div>
      <p class="eyebrow">Publications</p>
      <h1>Selected output across comfort, control, climate, and design intelligence.</h1>
      <p class="page-summary">
        Selected publications and conference papers since joining HKU in September 2023,
        based on the CV and subsequent updates.
      </p>
    </div>
  </section>

  <section class="publication-groups clean-groups">
    {groups.map((group) => (
      <div class="section-shell">
        <div class="section-header compact-header">
          <p class="eyebrow">{group.title}</p>
          <p class="section-count">{group.items.length} items</p>
        </div>
        <div class="publication-card-grid">
          {group.items.map((item) => (
            <article class="publication-card">
              <p class="publication-meta">{item.venue} · {item.year}</p>
              <h2 class="publication-title">{item.title}</h2>
              {group.kind === "journal" ? (
                <>
                  <p class="publication-summary">{item.summary || item.note || item.venue}</p>
                  <p class="note">{item.authors}</p>
                  {item.doi && (
                    <a
                      class="publication-link"
                      href={item.doi}
                      target="_blank"
                      rel="noreferrer"
                      style={`--hover-color: ${publicationColor(item)};`}
                    >
                      Read paper <span class="link-arrow" aria-hidden="true">-&gt;</span>
                    </a>
                  )}
                  <div class="publication-tags">
                    {item.tags?.map((tag) => (
                      <span>{tag}</span>
                    ))}
                  </div>
                </>
              ) : (
                <>
                  <p>{item.note || item.venue}</p>
                  <p class="note">{item.authors}</p>
                  <div class="publication-tags">
                    <span>{item.venue}</span>
                    <span>{item.year}</span>
                    <span>{item.status}</span>
                  </div>
                </>
              )}
            </article>
          ))}
        </div>
      </div>
    ))}
  </section>
</BaseLayout>
