---
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  appointments,
  education,
  links,
  profile,
  publicScholarship,
  service,
  supervision,
  teaching
} from "../data/site";
---

<BaseLayout
  title="PI | FORGE"
  description="PI profile, appointments, teaching, mentorship, and service for FORGE."
  activePath="/pi"
>
  <section class="pi-hero">
    <div class="pi-copy">
      <p class="eyebrow">Principal investigator</p>
      <h1>{profile.name}</h1>
      <p class="hero-lead">
        {profile.role}, {profile.department}, {profile.institution}
      </p>
      <p class="hero-summary">Human-building-climate systems, simulation, climate futures, and design-facing AI.</p>
      <ul class="inline-links" aria-label="Profile links">
        {links.map((link) => (
          <li><a href={link.href}>{link.label}</a></li>
        ))}
      </ul>
    </div>
    <div class="image-card">
      <img
        class="profile-image"
        src="/images/profile.png"
        alt="Portrait of Hongshan Guo"
        width="548"
        height="516"
      />
    </div>
  </section>

  <section class="home-columns">
    <div class="section-shell">
      <div class="section-header">
        <p class="eyebrow">Appointments</p>
        <h2>Academic and professional trajectory</h2>
      </div>
      <div class="list-articles">
        {appointments.map((item) => (
          <article class="article-row compact-row">
            <p class="article-meta">{item.years}</p>
            <h3>{item.title}</h3>
            <p class="note">{item.org}</p>
            <p>{item.detail}</p>
          </article>
        ))}
      </div>
    </div>

    <div class="section-shell">
      <div class="section-header">
        <p class="eyebrow">Education</p>
        <h2>Training and disciplinary base</h2>
      </div>
      <div class="list-articles">
        {education.map((item) => (
          <article class="article-row compact-row">
            <p class="article-meta">{item.year}</p>
            <h3>{item.degree}</h3>
            <p>{item.school}</p>
            {item.detail && <p class="note">{item.detail}</p>}
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="home-columns">
    <div class="section-shell">
      <div class="section-header">
        <p class="eyebrow">Teaching</p>
        <h2>Courses and pedagogy</h2>
      </div>
      <div class="list-articles">
        {teaching.courses.map((course) => (
          <article class="article-row compact-row">
            <p class="article-meta">{course.years}</p>
            <h3>{course.code}: {course.title}</h3>
            <p>{course.description}</p>
            <p class="note">{course.audience}</p>
            <a class="text-link" href={course.href}>Course site</a>
          </article>
        ))}
      </div>
      <p class="note">{teaching.pedagogy}</p>
      <p class="note">{teaching.prior}</p>
    </div>

    <div class="section-shell quiet-shell">
      <div class="section-header">
        <p class="eyebrow">Mentorship and service</p>
        <h2>Doctoral work, reviewing, and public-facing scholarship</h2>
      </div>
      <p class="list-label">Current supervision</p>
      <ul class="statement-list compact-list">
        {supervision.doctoral.map((item) => (
          <li>{item}</li>
        ))}
        {supervision.theses.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
      <p class="list-label">Professional service</p>
      <ul class="statement-list compact-list">
        {service.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
      <p class="list-label">Public scholarship</p>
      <ul class="statement-list compact-list">
        {publicScholarship.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </div>
  </section>
</BaseLayout>
