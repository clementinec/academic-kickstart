---
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  contributions,
  expertise,
  lab,
  honors,
  supervision
} from "../data/site";
---

<BaseLayout
  title="Research | FORGE"
  description="Research themes, expertise, and current directions for FORGE."
  activePath="/research"
>
  <section class="page-intro">
    <div>
      <p class="eyebrow">{lab.name}</p>
      <h1>Building intelligence for climate-stressed environments.</h1>
      <p class="page-summary">
        Work spans digital twins, probabilistic design exploration, physics-informed
        learning, and scenario-conditioned climate analysis for buildings, cities, and
        public institutions.
      </p>
    </div>
  </section>

  <section class="feature-grid">
      {contributions.map((item, index) => (
        <article class="feature-panel">
          <p class="eyebrow">Contribution 0{index + 1}</p>
          <h2>{item.title}</h2>
          <p>{item.text}</p>
        </article>
      ))}
  </section>

  <section class="page-grid">
    {expertise.map((group) => (
      <div class="section-shell">
        <div class="section-header">
          <p class="eyebrow">Research area</p>
          <h2>{group.area}</h2>
        </div>
        <ul class="statement-list">
          {group.items.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </div>
    ))}
  </section>

  <section class="page-grid">
    <div class="section-shell">
      <div class="section-header">
        <p class="eyebrow">Supervision</p>
        <h2>Mentorship in progress</h2>
      </div>
      <ul class="statement-list">
        {supervision.doctoral.map((item) => (
          <li>{item}</li>
        ))}
        {supervision.theses.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </div>
    <div class="section-shell">
      <div class="section-header">
        <p class="eyebrow">Funding and honors</p>
        <h2>Recent recognition</h2>
      </div>
      <ul class="statement-list">
        {honors.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </div>
  </section>

  <section class="section-shell emphasis-shell">
    <div class="section-header">
      <p class="eyebrow">Research position</p>
      <h2>A design-science lab mindset</h2>
    </div>
    <p>
      FORGE does not sit neatly inside a conventional faculty-template split of
      “research”, “teaching”, and “service”. The through-line is evidence: methods
      rigorous enough for standards and policy, but legible enough for design studios,
      public institutions, and cross-disciplinary collaborations.
    </p>
  </section>
</BaseLayout>
