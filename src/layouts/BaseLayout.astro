---
import "@fontsource/dm-serif-text/400.css";
import "@fontsource/ibm-plex-mono/400.css";
import "@fontsource/outfit/400.css";
import "@fontsource/outfit/500.css";
import "@fontsource/poppins/400.css";
import "@fontsource/poppins/500.css";
import "@fontsource/righteous/400.css";
import "../styles/global.css";

const {
  title = "FORGE",
  description = "FORGE: Future, Occupant, Risk, and Generative Environments at The University of Hong Kong.",
  activePath = "/"
} = Astro.props;

const navItems = [
  { href: "/", label: "Home" },
  { href: "/research", label: "Research" },
  { href: "/publications", label: "Publications" },
  { href: "/team", label: "Team" },
  { href: "/pi", label: "PI" }
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#ece6db" />
  </head>
  <body>
    <div class="site-shell">
      <header class="site-nav">
        <a class="brand" href="/">
          <span class="brand-text">FORGE</span>
          <span class="brand-meta">Future, Occupant, Risk, and Generative Environments</span>
        </a>
        <nav aria-label="Primary">
          <ul class="nav-links">
            {navItems.map((item) => (
              <li>
                <a
                  href={item.href}
                  class:list={[
                    "nav-link",
                    {
                      active:
                        item.href === "/"
                          ? activePath === "/"
                          : activePath.startsWith(item.href)
                    }
                  ]}
                >
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
        <a class="nav-cta" href="/cv.pdf">CV</a>
      </header>
      <main>
        <div class="page-shell">
          <slot />
        </div>
      </main>
      <footer class="site-footer">
        <p>FORGE at HKU.</p>
        <p>Content refreshed from the CV dated February 27, 2026.</p>
      </footer>
    </div>
  </body>
</html>
